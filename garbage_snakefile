
rule create_anndata:
    input:
        nb="01_create_anndata_object.ipynb",
        init="results/.init_done"
    output:
        nb="results/papermill/01_create_anndata_object.ipynb",
        adata=lambda wc, config: config["paths"]["adata_filtered"]
    params:
        counts=lambda wc, config: config["paths"]["counts"],
        metadata=lambda wc, config: config["paths"]["metadata"],
        gene_id=lambda wc, config: config["01_create_anndata_object"]["gene_id_col"],
        condition_columns=lambda wc, config: config["01_create_anndata_object"]["condition_columns"],
        filtering_sum=lambda wc, config: config["01_create_anndata_object"]["filtering_sum"],
        adata_out=lambda wc, config: config["paths"]["adata_filtered"]
    shell:
        """
        papermill {input.nb} {output.nb} \
            -p path_to_your_data "{params.counts}" \
            -p path_to_your_metadata "{params.metadata}" \
            -p gene_id_col "{params.gene_id}" \
            -p condition_columns "{params.condition_columns}" \
            -p filtering_sum {params.filtering_sum} \
            -p adata_output "{params.adata_out}"
        """

rule data_exploration:
    input:
        nb="02_data_exploration.ipynb",
        adata=lambda wc, config: config["paths"]["adata_filtered"]
    output:
        nb="results/papermill/02_data_exploration.ipynb"
    params:
        condition=lambda wc, config: config["general"]["condition"],
        design=lambda wc, config: config["02_data_exploration"]["design"]
    shell:
        """
        papermill {input.nb} {output.nb} \
            -p path_adata_filter "{input.adata}" \
            -p condition "{params.condition}" \
            -p design "{params.design}"
        """


rule create_contrasts:
    input:
        nb="03_create_contrast.ipynb",
        adata=lambda wc, config: config["paths"]["adata_filtered"]
    output:
        nb="results/papermill/03_create_contrast.ipynb",
        csvs=CONTRAST_OUTPUTS
    params:
        paired_contrast=lambda wc, config: config["03_create_contrast"]["paired_contrast"],
        condition=lambda wc, config: config["general"]["condition"],
        design=lambda wc, config: config["03_create_contrast"]["design"]
    shell:
        """
        papermill {input.nb} {output.nb} \
            -p paired_contrast '{params.paired_contrast}' \
            -p condition "{params.condition}" \
            -p design "{params.design}" \
            -p path_adata_filter "{input.adata}"
        """